# == DATOS Y ALMACENAMIENTO ==
# Bloquea los archivos dentro de la carpeta pero permite rastrear la estructura
data/**
# Excepciones: NO ignores las carpetas ni los archivos .gitkeep
!data/
!data/**/
!**/.gitkeep

# Extensiones globales que no se subirán
*.csv
*.xlsx
*.json
# Excepción: permitir el config de reglas
!**/rules_config.json

# == CREDENCIALES Y SECRETOS ==
.env
*.env

# == RESPALDOS DE PYTHON Y JUPYTER ==
.ipynb_checkpoints/
__pycache__/
*.pyc
.pytest_cache/
# Entornos virtuales (incluye el .venv_check de la verificacion en entorno limpio)
.venv/
.venv*/

# == SISTEMA OPERATIVO ==
.DS_Store
Thumbs.db
