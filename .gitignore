# == DATOS Y ALMACENAMIENTO ==
# Bloquea los archivos dentro de la carpeta pero permite rastrear la estructura
data/**
# Excepciones: NO ignores las carpetas ni los archivos .gitkeep
!data/
!data/**/
!**/.gitkeep

# Extensiones globales que no se subirán
*.csv
*.xlsx
*.json
# Excepción: permitir el config de reglas
!**/rules_config.json
# Excepción: config de inferencia del LLM (versionada, reproducible), #122
!**/llm_config.json
# Excepción: el pool auditado de ejemplos few-shot es DATO versionado (no output), #99
!**/fewshot_pool.json
# Excepción: base de conocimiento de dominio del prompt de Fase 3, versionada, #151
!**/domain_kb.json
# Excepción: fixtures de evidencia (corridas de LLM congeladas como insumo, no output
# efímero): se versionan a propósito para reuso sin re-gastar API (#99 → #95).
!03_llm_integration/fixtures/
!03_llm_integration/fixtures/**

# == CREDENCIALES Y SECRETOS ==
.env
*.env

# == RESPALDOS DE PYTHON Y JUPYTER ==
.ipynb_checkpoints/
__pycache__/
*.pyc
.pytest_cache/
# Entornos virtuales (incluye el .venv_check de la verificacion en entorno limpio)
.venv/
.venv*/

# == SISTEMA OPERATIVO ==
.DS_Store
Thumbs.db
