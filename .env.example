# API keys por proveedor. Nombre estándar por proveedor; una key por persona, nunca se comparte.
# Nunca se commitea una key real: este archivo es solo plantilla, los valores van en .env (gitignored).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Ruta al CSV crudo. Default: data/raw/po_root_cause_synthetic.csv (relativa a la raíz del repo)
PO_CSV_PATH=

# Parámetros operativos de Fase 3 (cambian por entorno, no por lógica del producto).
# Opcionales: si faltan, el código usa su default. La config de inferencia
# (temperatura, modelos, etc.) NO va aquí: vive en 03_llm_integration/llm_config.json.
LLM_DELAY_SECONDS=
LLM_RETRY_SLEEP_SECONDS=
LLM_SAVE_EVERY=

# Modelo de la vista de red (Network Intelligence, agente de diagnóstico
# estratégico por actor). Opcional: default gpt-4o-mini si falta.
MODEL_CHOICE=

# ── Telegram Bot (Fase 4) ─────────────────────────────────────────────────
# Token del bot de Telegram. Consíguelo con @BotFather en Telegram.
TELEGRAM_BOT_TOKEN=

# IDs de Telegram autorizados (separados por coma). Vacío = nadie autorizado
# (fail-closed): el bot arranca pero rechaza todos los comandos.
# Para obtener tu ID, escribe /start a @userinfobot en Telegram.
TELEGRAM_USER_WHITELIST=

# IDs de Telegram con perfil "Ravi" (analista). El resto son "Diego".
# Vacío = todos son Diego.
TELEGRAM_RAVI_USER_IDS=
